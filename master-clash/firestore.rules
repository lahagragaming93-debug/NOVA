// ============================================================================
// Règles de sécurité Firestore — Master Clash (version durcie)
// À copier dans Firebase Console → Firestore Database → onglet "Règles"
//
// Stratégie :
// - L'admin (A.Beauchamp / alias BoulaTV) a tous les droits → identifié par son email Firebase
// - Reconnaît les DEUX emails admin pour assurer la transition :
//   - 'a.beauchamp@masterclash.local' (nouveau, post-NOVA)
//   - 'boulatv@masterclash.local' (legacy, conservé pour rétro-compatibilité des données)
// - Les utilisateurs nommés (non-anonymes) peuvent agir sur leurs propres
//   données uniquement
// - Les utilisateurs anonymes ont le minimum (juste lire l'index utilisateurs
//   pour la liste des partenaires + créer leur compte à l'inscription)
// - Tout le reste est explicitement bloqué (catch-all final)
//
// Convention : email Firebase = <username>@masterclash.local
// → permet d'extraire le username depuis l'email pour vérifier la propriété
// ============================================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPERS =====
    function isAuth() {
      return request.auth != null;
    }
    function isNamed() {
      return isAuth() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function isAdmin() {
      return isNamed() && (
        request.auth.token.email == 'a.beauchamp@masterclash.local'
        || request.auth.token.email == 'boulatv@masterclash.local'
      );
    }
    function isOwner(username) {
      return isNamed()
        && request.auth.token.email != null
        && request.auth.token.email == username.lower() + '@masterclash.local';
    }
    function ownerUsername() {
      return request.auth.token.email.replace('@masterclash.local', '');
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ===== USERS =====
    // Lecture : tout authentifié peut voir la liste (nécessaire pour rendu UI)
    // Création : tout authentifié (anonyme inclus) — pour permettre l'inscription
    //   MAIS on impose isAdmin == false pour bloquer l'auto-élévation
    // Update : admin = tout droits ; owner = tout sauf isAdmin/perms ; sinon ❌
    // Delete : admin only
    match /users/{username} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.isAdmin == false;
      allow update: if isAdmin()
        || (isOwner(username)
            && !changedKeys().hasAny(['isAdmin', 'perms', 'username']));
      allow delete: if isAdmin();
    }

    // ===== MESSAGES =====
    // Lecture : admin voit tout, sinon il faut être participant du thread
    // Création : tout authentifié peut envoyer un message
    // Update : participant ou admin
    // Delete : admin only
    match /messages/{threadId} {
      allow read: if isAdmin()
        || (isNamed()
            && resource != null
            && resource.data.participants is list
            && resource.data.participants.hasAny([ownerUsername()]));
      allow create: if isAuth();
      allow update: if isAdmin()
        || (isNamed()
            && resource.data.participants.hasAny([ownerUsername()]));
      allow delete: if isAdmin();
    }

    // ===== PARTICIPANTS =====
    // Lecture : tout authentifié (liste publique des inscrits au quiz)
    // Création : tout authentifié peut s'inscrire
    // Update : admin (statut, groupe) ou propriétaire (modifier ses infos)
    // Delete : admin only (sauf si tu te désinscris toi-même)
    match /participants/{participantId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin()
        || (isNamed() && resource.data.username == ownerUsername());
      allow delete: if isAdmin()
        || (isNamed() && resource.data.username == ownerUsername());
    }

    // ===== CONTRACTS =====
    // Lecture : admin voit tout, partenaires voient seulement leurs contrats
    // Création : tout authentifié peut soumettre un contrat
    // Update/Delete : admin only (validation, archivage)
    match /contracts/{contractId} {
      allow read: if isAdmin()
        || (isNamed() && resource.data.createdBy == ownerUsername());
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ===== CONFIG (budget, allocations) =====
    // Lecture : tout authentifié (info utile pour les partenaires)
    // Écriture : admin only
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ===== CATCH-ALL : tout le reste bloqué =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
