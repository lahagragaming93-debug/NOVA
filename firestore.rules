// ============================================================================
// NOVA — Règles de sécurité Firestore (PORTAIL UNIFIÉ)
// À copier dans Firebase Console → Firestore Database → onglet "Règles"
// → puis cliquer "Publier"
//
// Ce fichier protège DEUX espaces dans le même projet Firebase nova-association :
//
//   1) NOVA (espace asso)         → collections : users, transactions, documents,
//      membres, partenaires, threads/{tid}/messages/{mid}, journal
//      Email Bureau (président)   : a.beauchamp@nova-association.com
//
//   2) Master Clash (projet 1)    → collections préfixées "mc_*" :
//      mc_users, mc_messages, mc_participants, mc_contracts, mc_config
//      Email admin                : a.beauchamp@masterclash.local
//                                 + boulatv@masterclash.local (legacy rétro-compat)
//
// Les deux espaces partagent le pool Firebase Auth mais sont isolés par paths.
// Un compte créé côté NOVA n'a pas d'autorisation côté MC (et vice versa) car
// chaque espace lit ses propres docs profil pour résoudre les rôles.
// ============================================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPERS COMMUNS
    // ========================================================================
    function isAuth() {
      return request.auth != null;
    }

    // ========================================================================
    // ESPACE NOVA — helpers
    // ========================================================================
    function novaUserDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function novaRole() {
      return novaUserDoc(request.auth.uid).role;
    }

    function isPresident() {
      return isAuth() && novaRole() == 'president';
    }

    function isTresorier() {
      return isAuth() && novaRole() == 'tresorier';
    }

    function isSecretaire() {
      return isAuth() && novaRole() == 'secretaire';
    }

    function isBureau() {
      return isPresident() || isTresorier() || isSecretaire();
    }

    function isPresidentEmail() {
      return isAuth() && request.auth.token.email == 'a.beauchamp@nova-association.com';
    }

    // ========================================================================
    // ESPACE MASTER CLASH — helpers
    // ========================================================================
    function mcIsNamed() {
      return isAuth() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function mcIsAdmin() {
      return mcIsNamed() && (
        request.auth.token.email == 'a.beauchamp@masterclash.local'
        || request.auth.token.email == 'boulatv@masterclash.local'
      );
    }

    function mcIsOwner(username) {
      return mcIsNamed()
        && request.auth.token.email != null
        && request.auth.token.email == username.lower() + '@masterclash.local';
    }

    function mcOwnerUsername() {
      return request.auth.token.email.replace('@masterclash.local', '');
    }

    function mcChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isMcUser() {
      return isAuth()
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@masterclash[.]local');
    }

    // ========================================================================
    // ============================  NOVA  ====================================
    // ========================================================================

    // ===== USERS (NOVA) =====
    // Profils utilisateurs (un doc par utilisateur, id = uid)
    match /users/{uid} {
      allow read: if isAuth() && !isMcUser();

      allow create: if isAuth() && request.auth.uid == uid && !isMcUser()
        && (
          request.resource.data.role == 'utilisateur'
          || (request.resource.data.role == 'president' && isPresidentEmail())
        );

      allow update: if isPresident()
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.email == resource.data.email
            && request.resource.data.username == resource.data.username);

      allow delete: if isPresident();
    }

    // ===== TRANSACTIONS (compta NOVA) =====
    match /transactions/{txId} {
      allow read:   if isBureau();
      allow create: if isBureau();
      allow update: if isPresident() || isTresorier();
      allow delete: if isPresident();
    }

    // ===== DOCUMENTS (instances de templates NOVA) =====
    match /documents/{docId} {
      allow read:   if isBureau()
        || (isAuth() && resource.data.targetUid == request.auth.uid);
      allow create: if isBureau();
      allow update: if isBureau();
      allow delete: if isPresident();
    }

    // ===== MEMBRES (registre NOVA) =====
    match /membres/{memberId} {
      allow read:   if isBureau();
      allow create: if isBureau();
      allow update: if isPresident() || isSecretaire();
      allow delete: if isPresident();
    }

    // ===== PARTENAIRES (NOVA) =====
    match /partenaires/{partenaireId} {
      allow read:   if isBureau()
        || (isAuth() && novaRole() == 'partenaire' && resource.data.userUid == request.auth.uid)
        || (resource.data.vitrine == true && resource.data.statut == 'actif');
      allow create: if isBureau();
      allow update: if isPresident() || isSecretaire();
      allow delete: if isPresident();
    }

    // ===== THREADS DE MESSAGERIE (NOVA) =====
    match /threads/{tid} {
      allow read: if isAuth()
        && resource.data.participants is list
        && resource.data.participants.hasAny([request.auth.uid]);

      allow create: if isAuth()
        && request.resource.data.participants is list
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuth()
        && resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if isAuth()
        && (resource.data.createdBy == request.auth.uid || isPresident());

      match /messages/{mid} {
        function threadParticipants() {
          return get(/databases/$(database)/documents/threads/$(tid)).data.participants;
        }
        allow read: if isAuth() && threadParticipants().hasAny([request.auth.uid]);
        allow create: if isAuth()
          && threadParticipants().hasAny([request.auth.uid])
          && request.resource.data.from == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ===== JOURNAL D'ACTIVITÉ (NOVA, audit log) =====
    match /journal/{entryId} {
      allow read:   if isBureau();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ========================================================================
    // ========================  MASTER CLASH  ================================
    // ========================================================================

    // ===== MC_USERS =====
    match /mc_users/{username} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.isAdmin == false;
      allow update: if mcIsAdmin()
        || (mcIsOwner(username)
            && !mcChangedKeys().hasAny(['isAdmin', 'perms', 'username']));
      allow delete: if mcIsAdmin();
    }

    // ===== MC_MESSAGES =====
    match /mc_messages/{threadId} {
      allow read: if mcIsAdmin()
        || (mcIsNamed()
            && resource != null
            && resource.data.participants is list
            && resource.data.participants.hasAny([mcOwnerUsername()]));
      allow create: if isAuth();
      allow update: if mcIsAdmin()
        || (mcIsNamed()
            && resource.data.participants.hasAny([mcOwnerUsername()]));
      allow delete: if mcIsAdmin();
    }

    // ===== MC_PARTICIPANTS =====
    match /mc_participants/{participantId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if mcIsAdmin()
        || (mcIsNamed() && resource.data.username == mcOwnerUsername());
      allow delete: if mcIsAdmin()
        || (mcIsNamed() && resource.data.username == mcOwnerUsername());
    }

    // ===== MC_CONTRACTS =====
    match /mc_contracts/{contractId} {
      allow read: if mcIsAdmin()
        || (mcIsNamed() && resource.data.createdBy == mcOwnerUsername());
      allow create: if isAuth();
      allow update, delete: if mcIsAdmin();
    }

    // ===== MC_CONFIG =====
    match /mc_config/{docId} {
      allow read: if isAuth();
      allow write: if mcIsAdmin();
    }

    // ========================================================================
    // CATCH-ALL : tout le reste bloqué
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
